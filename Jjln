def auto_tag_worker(context):
    jakarta_tz = pytz.timezone("Asia/Jakarta")

    while True:
        try:
            now = datetime.now(jakarta_tz)
            current_hour = now.hour
            current_minute = now.minute
            tanggal = now.strftime("%d-%m-%Y")

            for user_id, data in list(auto_data.items()):
                target_chat = None
                try:
                    if not data.get("active") or data.get("hour") is None:
                        continue

                    # рҹ”Ҙ CEK JAM & MENIT
                    if current_hour != data["hour"] or current_minute != data.get("minute", 0):
                        continue

                    # рҹ”Ҙ 1x sehari (WAJIB)
                    if data.get("last_run") == tanggal:
                        continue

                    target_chat = int(data.get("chat_id", user_id))
                    text = data.get("text", "AUTO TAGALL")

                    # рҹ”Ҙ ANTI DUPLICATE MEMORY
                    msg_key = f"{target_chat}_{text}_{tanggal}"
                    if msg_key in recent_messages:
                        continue
                    recent_messages.add(msg_key)

                    # рҹ”Ҙ RATE LIMIT
                    if rate_limit.get(target_chat, 0) > 5:
                        context.bot.send_message(
                            LOG_CHAT_ID,
                            f"вӣ” RATE LIMIT SKIP\nрҹҺҜ {target_chat}"
                        )
                        continue

                    # рҹ”Ҙ LOG START
                    context.bot.send_message(
                        LOG_CHAT_ID,
                        f"рҹҡҖ AUTO TAG JALAN\n"
                        f"рҹ“… {tanggal}\n"
                        f"рҹ‘Ө {user_id}\n"
                        f"рҹҺҜ {target_chat}\n"
                        f"рҹ•’ {data['hour']:02d}:{data.get('minute',0):02d} WIB"
                    )

                    success = False

                    # рҹ”Ҙ RETRY SYSTEM
                    for attempt in range(5):
                        try:
                            delay = random.uniform(2, 5) + (attempt * random.uniform(1, 3))
                            time.sleep(delay)

                            duration = data.get("duration", 10) * 60

                            run_tagall_manual(context, target_chat, text, "normal", duration)

                            # вң… SUCCESS
                            success = True
                            rate_limit[target_chat] = max(0, rate_limit.get(target_chat, 0) - 1)
                            last_activity[target_chat] = time.time()

                            context.bot.send_message(
                                LOG_CHAT_ID,
                                f"вң… AUTO TAG SELESAI\n"
                                f"рҹ‘Ө {user_id}\n"
                                f"рҹҺҜ {target_chat}\n"
                                f"вҸұ {data.get('duration',10)} menit"
                            )
                            break

                        except Exception as e:
                            print(f"[RETRY {attempt+1}] ERROR:", e)

                            try:
                                context.bot.send_message(
                                    LOG_CHAT_ID,
                                    f"вҡ пёҸ RETRY {attempt+1}\n"
                                    f"рҹ‘Ө {user_id}\n"
                                    f"рҹҺҜ {target_chat}\n"
                                    f"ERROR: {e}"
                                )
                            except Exception as log_err:
                                print("LOG ERROR:", log_err)

                            if "Too Many Requests" in str(e):
                                rate_limit[target_chat] = rate_limit.get(target_chat, 0) + 1
                                time.sleep(random.uniform(5, 10))

                    # вқҢ GAGAL TOTAL
                    if not success:
                        print("вқҢ GAGAL TOTAL:", target_chat)
                        context.bot.send_message(
                            LOG_CHAT_ID,
                            f"вқҢ GAGAL TOTAL AUTO TAG\n"
                            f"рҹ‘Ө {user_id}\n"
                            f"рҹҺҜ {target_chat}"
                        )

                    # рҹ”Ҙ SAVE LAST RUN
                    auto_data[user_id]["last_run"] = tanggal
                    try:
                        save_autotag()
                    except Exception as e:
                        print("SAVE ERROR:", e)
                        context.bot.send_message(
                            LOG_CHAT_ID,
                            f"вқҢ SAVE ERROR\n{e}\nрҹ‘Ө {user_id}"
                        )

                except Exception as e:
                    print("USER LOOP ERROR:", e)
                    try:
                        context.bot.send_message(
                            LOG_CHAT_ID,
                            f"вқҢ USER LOOP ERROR\n"
                            f"рҹ‘Ө {user_id}\n"
                            f"рҹҺҜ {target_chat}\n"
                            f"{e}"
                        )
                    except Exception as log_err:
                        print("LOG ERROR:", log_err)

            # рҹ”Ҙ CLEAN MEMORY
            if len(recent_messages) > 500:
                recent_messages.clear()

            for chat in list(rate_limit.keys()):
                if time.time() - last_activity.get(chat, 0) > 60:
                    rate_limit[chat] = 0

        except Exception as e:
            print("WORKER FATAL ERROR:", e)
            try:
                context.bot.send_message(
                    LOG_CHAT_ID,
                    f"вқҢ WORKER FATAL ERROR\n{e}"
                )
            except Exception as log_err:
                print("LOG ERROR:", log_err)

        time.sleep(5)

