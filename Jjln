def load_setting():
    import os
    import json

    if not os.path.exists(SETTING_FILE):
        return {}

    try:
        with open(SETTING_FILE, "r") as f:
            data = json.load(f)

            if not isinstance(data, dict):
                return {}

            return data

    except Exception as e:
        print("вқҢ LOAD SETTING ERROR:", e)
        return {}


def save_setting(data):
    import json
    import os
    import time
    import shutil

    try:
        # ================= VALIDASI =================
        if not isinstance(data, dict):
            data = {}

        # ================= AUTO BACKUP =================
        if os.path.exists(SETTING_FILE):
            backup_dir = "backup_settings"

            if not os.path.exists(backup_dir):
                os.makedirs(backup_dir)

            timestamp = int(time.time())
            backup_file = f"{backup_dir}/setting_{timestamp}.json"

            shutil.copy(SETTING_FILE, backup_file)
            print(f"рҹ“Ұ Backup dibuat: {backup_file}")

        # ================= SAFE SAVE =================
        temp_file = SETTING_FILE + ".tmp"

        with open(temp_file, "w") as f:
            json.dump(data, f, indent=2)

        os.replace(temp_file, SETTING_FILE)

        print("вң… SETTING KE SAVE")

        # ================= AUTO CLEAN (BIAR GA NUMPUK) =================
        backups = sorted(os.listdir("backup_settings"))

        if len(backups) > 10:  # simpan max 10 backup
            for old in backups[:-10]:
                os.remove(f"backup_settings/{old}")
                print(f"рҹ—‘пёҸ Backup lama dihapus: {old}")

    except Exception as e:
        print("вқҢ SAVE SETTING ERROR:", e)


