def restore_cmd(update, context):
    if update.effective_user.id != OWNER_ID:
        return

    if not update.message.reply_to_message or not update.message.reply_to_message.document:
        update.message.reply_text("вқҢ reply file zip dengan /restore")
        return

    try:
        update.message.reply_text("вҸі restore sedang diproses...")

        # ================= DOWNLOAD =================
        file = update.message.reply_to_message.document.get_file()
        file.download("restore.zip")

        import zipfile
        import os
        import time

        # ================= VALIDASI ZIP =================
        if not zipfile.is_zipfile("restore.zip"):
            update.message.reply_text("вқҢ file bukan zip valid")
            return

        with zipfile.ZipFile("restore.zip", 'r') as z:
            files = z.namelist()

            # ================= VALIDASI ISI (FIX AMAN) =================
            valid = (
                "setting.json8" in files or
                "partner.json10" in files or
                "buttons.json" in files or
                "autotag.json" in files
            )

            if not valid:
                update.message.reply_text("вқҢ isi zip tidak valid")
                return

            # ================= BACKUP LAMA =================
            backup_name = f"backup_before_restore_{int(time.time())}.zip"
            with zipfile.ZipFile(backup_name, 'w') as backup:
                if os.path.exists("partner.json10"):
                    backup.write("partner.json10")
                if os.path.exists("setting.json8"):
                    backup.write("setting.json8")

                # рҹ”Ҙ TAMBAHAN
                if os.path.exists("buttons.json"):
                    backup.write("buttons.json")
                if os.path.exists("autotag.json"):
                    backup.write("autotag.json")

                if os.path.exists("database8"):
                    for root, dirs, files2 in os.walk("database8"):
                        for f in files2:
                            backup.write(os.path.join(root, f))

            # ================= EXTRACT =================
            z.extractall()

        update.message.reply_text("вң… restore sukses, bot akan restart...")

        # ================= AUTO RESTART =================
        os.execv("/root/autobot/venv/bin/python", ["python", "bot2.py"])

    except Exception as e:
        update.message.reply_text(f"вқҢ restore gagal\n{e}")

